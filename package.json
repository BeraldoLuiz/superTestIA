{
  "name": "supertestia",
  "version": "1.0.0",
  "description": "External API testing with SuperTest + Jest",
  "type": "commonjs",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --runInBand --passWithNoTests",
    "test:functional": "jest tests/functional --passWithNoTests",
    "test:contract": "jest tests/contract --passWithNoTests",
    "test:pokemon": "jest pokemon --passWithNoTests",
    "test:type": "jest type --passWithNoTests",
    "test:ability": "jest ability --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "supertest",
    "jest",
    "api",
    "e2e",
    "testing"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "prettier": "^3.8.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "zod": "^4.4.3"
  }
}
